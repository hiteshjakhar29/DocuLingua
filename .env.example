# ==============================================================================
# DocuLingua Environment Configuration — EXAMPLE
# ==============================================================================
# Copy this file to .env and replace every placeholder value before running.
#
#   cp .env.example .env
#
# NEVER commit the real .env to version control — it contains secrets.
# .env is already listed in .gitignore.
# ==============================================================================

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
# Ensures backend modules resolve correctly when running scripts directly
# (outside Docker). Leave this as-is.
PYTHONPATH=.

# ------------------------------------------------------------------------------
# Database — PostgreSQL
# ------------------------------------------------------------------------------

# Username that PostgreSQL will create for the DocuLingua database.
# Used by both the "db" Docker Compose service and the DATABASE_URL below.
# Example: doculingua
POSTGRES_USER=doculingua

# Password for the PostgreSQL user above.
# Must match the password embedded in DATABASE_URL.
# Generate a strong value with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Example: Xy9#mKpL2$vQnRt8
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD

# Name of the PostgreSQL database to create and use.
# Example: doculingua
POSTGRES_DB=doculingua

# Full SQLAlchemy connection URL consumed by the FastAPI backend.
# Format:  postgresql://<user>:<password>@<host>:<port>/<database>
#
# Host rules:
#   - Inside Docker Compose  → use "db"        (the service name)
#   - Running locally        → use "localhost"  (PostgreSQL must be running)
#
# IMPORTANT: The password here must match POSTGRES_PASSWORD above.
# SQLite is explicitly rejected at startup — PostgreSQL is required.
#
# Example (Docker):  postgresql://doculingua:yourpassword@db:5432/doculingua
# Example (local):   postgresql://doculingua:yourpassword@localhost:5432/doculingua
DATABASE_URL=postgresql://doculingua:CHANGE_THIS_PASSWORD@localhost:5432/doculingua

# ------------------------------------------------------------------------------
# API Server
# ------------------------------------------------------------------------------

# Interface the Uvicorn server binds to.
# 0.0.0.0 = accept connections on all interfaces (correct for Docker).
API_HOST=0.0.0.0

# Port Uvicorn listens on. Exposed as localhost:8000 via docker-compose.yml.
# Change only if port 8000 is already occupied on your machine.
API_PORT=8000

# Long-lived secret used for signing internal tokens.
# Must be a long, random, unpredictable string — keep it private.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Example: a3f8c2e1d94b7065f2a1c3e8b5d2f6a4c7e9b1d3f5a7c9e2b4d6f8a0c2e4b6d8
SECRET_KEY=GENERATE_YOUR_OWN_SECRET_KEY_HERE

# API key that clients must supply in the X-API-Key request header.
# All endpoints except GET /health require this key.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Example: wK3mXp9nQr7sYv2uZj5tBh8cDf4eGi6k
API_KEY=GENERATE_YOUR_OWN_KEY_HERE

# ------------------------------------------------------------------------------
# Frontend (Streamlit)
# ------------------------------------------------------------------------------

# URL the Streamlit frontend uses to reach the FastAPI backend.
# Inside Docker Compose → http://api:8000   (service-to-service DNS)
# Running locally       → http://localhost:8000
API_URL=http://api:8000

# ------------------------------------------------------------------------------
# ML / Model Paths
# ------------------------------------------------------------------------------

# Directory containing trained model artifacts (BERT classifier + spaCy NER).
# This path is relative to the project root and mounted as a Docker volume.
# Total model footprint is approximately 2 GB.
# Example: models
MODEL_DIR=models

# HuggingFace Transformers download cache.
# Persisted as a named Docker volume (hf_cache:) to avoid re-downloading
# the ~1.8 GB multilingual BERT weights on every container restart.
TRANSFORMERS_CACHE=/app/.cache/huggingface
HF_HOME=/app/.cache/huggingface

# ------------------------------------------------------------------------------
# File Storage
# ------------------------------------------------------------------------------

# Directory where uploaded documents are temporarily cached during OCR.
# PDFs are rasterized to PNG here and cleaned up after analysis completes.
# Example: uploads
UPLOAD_DIR=uploads

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------

# Logging verbosity. Choices: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use INFO for normal operation; DEBUG for development / troubleshooting.
LOG_LEVEL=INFO

# Set to "true" to enable Uvicorn hot-reload and verbose error pages.
# Must be "false" in production.
DEBUG=false
