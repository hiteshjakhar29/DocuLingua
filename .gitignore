# ==============================================================================
# DocuLingua — .gitignore
# ==============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
venv_synth/
env/
ENV/

# ── Secrets / environment ─────────────────────────────────────────────────────
# Keep .env.example (safe template); never commit the real .env
.env
.env.local

# ── Databases ─────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Trained ML models ─────────────────────────────────────────────────────────
# Classifier weights are ~680 MB per checkpoint — too large for git.
# Regenerate: python backend/ml_models/train_classifier.py
# Directory structure is preserved via models/classifier/.gitkeep
models/classifier/*
!models/classifier/.gitkeep

# spaCy NER model is ~15 MB and is committed as-is.
# Regenerate: python backend/ml_models/train_ner.py

# ── Runtime assets generated by the app ──────────────────────────────────────
uploads/
logs/
*.log

# ── Synthetic training data (regenerate with data/synthesize.py) ─────────────
data/synthetic_docs/

# ── HuggingFace / PyTorch caches ─────────────────────────────────────────────
.cache/
*.cache

# ── Build / packaging ────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
wheels/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Coverage / testing ────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
